{
  "name": "iarp-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "cd back && npm run dev",
    "build": "cd back && npm run build",
    "lint": "eslint back --ext .ts",
    "lint:fix": "eslint back --ext .ts --fix && prettier --write back",
    "install:all": "npm install && cd back && npm install",
    "update:all": "npm update && cd back && npm update"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.0.0",
    "prettier": "^3.8.0"
  }
}
